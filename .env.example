# Required: your Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API key for ada-002 embeddings (falls back to local HuggingFace model if not set)
OPENAI_API_KEY=

# PostgreSQL — matches docker-compose defaults for local dev
DATABASE_URL=postgresql://pipeline_doctor:CHANGE_ME@localhost:5432/pipeline_doctor
POSTGRES_PASSWORD=CHANGE_ME

# AWS — only needed for cloud deployment, not local dev
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=pipeline-doctor-manifests

# Slack webhook for failure alerts (optional)
# Create at: https://api.slack.com/apps -> Incoming Webhooks
SLACK_WEBHOOK_URL=

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
